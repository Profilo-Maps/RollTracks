# Supabase Configuration
# Get these from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# MapBox Configuration
# Get from: https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Service Role Key (for admin scripts only - DO NOT expose to client!)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# Required for: upload-curb-ramps-storage.js, seed-census-blocks.js
# ⚠️ WARNING: Keep this secret! Never commit to version control!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
