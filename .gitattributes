# Auto detect text files and perform LF normalization
* text=auto

# Force CRLF line endings on Windows for these files
*.md text eol=crlf
*.txt text eol=crlf
*.json text eol=crlf
*.js text eol=crlf
*.ts text eol=crlf
*.tsx text eol=crlf
*.jsx text eol=crlf
*.css text eol=crlf
*.scss text eol=crlf
*.html text eol=crlf
*.xml text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.sql text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
