{
  "expo": {
    "name": "RollTracks",
    "slug": "RollTracks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rolltracks",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rolltracks.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RollTracks needs your location to record your trips and display your route on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RollTracks needs your location to record your trips and display your route on the map.",
        "NSCameraUsageDescription": "RollTracks needs access to your camera to take photos of curb ramps and accessibility features.",
        "NSPhotoLibraryUsageDescription": "RollTracks needs access to your photo library to upload images of curb ramps and accessibility features."
      }
    },
    "android": {
      "largeHeap": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rolltracks.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "statusBar": {
        "translucent": true,
        "backgroundColor": "transparent"
      },
      "navigationBar": {
        "visible": false
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@rnmapbox/maps",
      [
        "expo-image-picker",
        {
          "photosPermission": "RollTracks needs access to your photo library to upload images of curb ramps and accessibility features.",
          "cameraPermission": "RollTracks needs access to your camera to take photos of curb ramps and accessibility features."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "ndkVersion": "27.1.12297006",
            "kotlinVersion": "2.0.21",
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            }
          }
        }
      ],
      "./plugins/withArgon2KtOverride",
      "./plugins/withDropLegacyArchs"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
